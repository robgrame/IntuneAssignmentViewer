@inherits LayoutComponentBase
@inject IOptions<BrandingSettings> BrandingOptions

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="@BrandingOptions.Value.LogoPath" alt="Logo" class="company-logo" onerror="this.style.display='none'" />
                <span class="fw-semibold">@BrandingOptions.Value.AppTitle</span>
            </div>
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted me-2">@context.User.Identity?.Name</span>
                    <a href="MicrosoftIdentity/Account/SignOut" class="btn btn-outline-secondary btn-sm">Sign Out</a>
                </Authorized>
                <NotAuthorized>
                    <a href="MicrosoftIdentity/Account/SignIn" class="btn btn-primary btn-sm">Sign In</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
