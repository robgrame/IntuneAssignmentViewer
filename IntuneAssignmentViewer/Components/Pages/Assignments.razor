@page "/assignments"
@rendermode InteractiveServer
@implements IDisposable
@inject IIntuneService IntuneService
@inject IConfiguration Configuration
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "RequireIntuneRole")]

<PageTitle>Intune Assignments</PageTitle>

<div class="assignments-container">
    <h2 class="mb-4">📋 Intune Assignment Viewer</h2>

    @if (selectedGroup == null)
    {
        <div class="search-section">
            <label class="form-label fw-semibold">Search Entra ID Group</label>
            <div class="position-relative">
                <input type="text" class="form-control form-control-lg search-input"
                       placeholder="Start typing a group name..."
                       @bind="searchTerm" @bind:event="oninput" @bind:after="OnSearchInput" />
                @if (isSearching)
                {
                    <div class="search-spinner">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </div>
                }
            </div>

            @if (groups.Any())
            {
                <div class="search-results mt-2">
                    @foreach (var group in groups)
                    {
                        <div class="search-result-item" @onclick="() => SelectGroup(group)">
                            <div class="d-flex align-items-center gap-2">
                                <span class="group-icon">👥</span>
                                <div>
                                    <div class="fw-semibold">@group.DisplayName</div>
                                    @if (!string.IsNullOrEmpty(group.Description))
                                    {
                                        <small class="text-muted">@group.Description</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(searchTerm) && searchTerm.Length >= 3 && !isSearching)
            {
                <div class="alert alert-light mt-2">No groups found matching "<strong>@searchTerm</strong>"</div>
            }

            <div class="quick-access mt-4">
                <div class="quick-access-label">Or view virtual targets:</div>
                <div class="quick-access-buttons">
                    <button class="quick-access-btn all-users" @onclick="SelectAllUsers">
                        <span class="qa-icon">🧑‍🤝‍🧑</span>
                        <div>
                            <div class="qa-title">All Users</div>
                            <small class="qa-desc">Every licensed user in the tenant</small>
                        </div>
                    </button>
                    <button class="quick-access-btn all-devices" @onclick="SelectAllDevices">
                        <span class="qa-icon">💻</span>
                        <div>
                            <div class="qa-title">All Devices</div>
                            <small class="qa-desc">Every Intune-enrolled device</small>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="selected-group-header mb-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <span class="group-icon-lg">@(IsVirtualGroup ? (selectedGroup.Id == IntuneAssignmentViewer.Services.IntuneService.VirtualAllUsersId ? "🧑‍🤝‍🧑" : "💻") : "👥")</span>
                    <div>
                        <h4 class="mb-0">
                            @selectedGroup.DisplayName
                            @if (IsVirtualGroup)
                            {
                                <span class="badge bg-info text-dark ms-2">Virtual</span>
                            }
                        </h4>
                        @if (!string.IsNullOrEmpty(selectedGroup.Description))
                        {
                            <small class="text-muted">@selectedGroup.Description</small>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary btn-sm" @onclick="RefreshAssignments" disabled="@isLoadingAssignments" title="Bypass cache and re-fetch from Microsoft Graph">
                        🔄 Refresh
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection">
                        ✕ Change Group
                    </button>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
            <div class="filter-tabs">
                <button class="filter-tab @(selectedFilter == null ? "active" : "")" @onclick="() => SetFilter(null)">
                    🔍 All
                </button>
                @foreach (var (type, icon, label) in PolicyTypeMeta)
                {
                    <button class="filter-tab @(selectedFilter == type ? "active" : "")" @onclick="() => SetFilter(type)">
                        @icon @label
                    </button>
                }
            </div>

            <div class="view-toggle">
                <button class="view-btn @(viewMode == ViewMode.Cards ? "active" : "")" @onclick="() => viewMode = ViewMode.Cards" title="Card view">
                    ▦ Cards
                </button>
                <button class="view-btn @(viewMode == ViewMode.Table ? "active" : "")" @onclick="() => viewMode = ViewMode.Table" title="Table view">
                    ☰ Table
                </button>
            </div>
        </div>

        @if (isLoadingAssignments)
        {
            <div class="loading-state">
                <div class="spinner-border text-primary"></div>
                <span>Loading assignments...</span>
            </div>
        }
        else if (assignments.Any())
        {
            <!-- ===== Summary dashboard ===== -->
            <div class="summary-section mb-4">
                <div class="summary-grid">
                    <div class="summary-card summary-total">
                        <div class="summary-total-value">@assignments.Count</div>
                        <div class="summary-total-label">Total Assignments</div>
                    </div>

                    <div class="summary-card">
                        <h6 class="summary-title">By Policy Type</h6>
                        @{
                            var byType = assignments.GroupBy(a => a.PolicyType)
                                .Select(g => new { Type = g.Key, Count = g.Count() })
                                .OrderByDescending(x => x.Count)
                                .ToList();
                            var maxTypeCount = byType.Max(x => x.Count);
                        }
                        <div class="bar-chart">
                            @foreach (var item in byType)
                            {
                                <div class="bar-row" @onclick="() => SetFilter(item.Type)" role="button">
                                    <div class="bar-label">
                                        <span>@GetPolicyIcon(item.Type)</span>
                                        <span>@GetPolicyLabel(item.Type)</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill @GetBarColorClass(item.Type)"
                                             style="width: @((item.Count * 100 / maxTypeCount))%"></div>
                                    </div>
                                    <div class="bar-value">@item.Count</div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="summary-card">
                        <h6 class="summary-title">By Platform</h6>
                        @{
                            var byPlatform = assignments
                                .Select(a => string.IsNullOrEmpty(a.Platform) ? "Cross-platform" : a.Platform)
                                .GroupBy(p => p)
                                .Select(g => new { Platform = g.Key, Count = g.Count() })
                                .OrderByDescending(x => x.Count)
                                .ToList();
                        }
                        <div class="donut-wrapper">
                            <svg viewBox="0 0 42 42" class="donut">
                                <circle class="donut-hole" cx="21" cy="21" r="15.91549430918954"></circle>
                                @{
                                    double offset = 25;
                                    var total = byPlatform.Sum(x => x.Count);
                                    int idx = 0;
                                    var palette = new[] { "#0078d4", "#5c2d91", "#107c10", "#ff8c00", "#e3008c", "#888" };
                                }
                                @foreach (var item in byPlatform)
                                {
                                    var pct = total == 0 ? 0 : (item.Count * 100.0 / total);
                                    var color = palette[idx % palette.Length];
                                    var dash = $"{pct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)} {(100 - pct).ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}";
                                    var dashOffset = offset.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                    <circle class="donut-segment"
                                            cx="21" cy="21" r="15.91549430918954"
                                            stroke="@color"
                                            stroke-dasharray="@dash"
                                            stroke-dashoffset="@dashOffset"></circle>
                                    offset = (offset - pct + 100) % 100;
                                    idx++;
                                }
                            </svg>
                            <div class="donut-legend">
                                @{ idx = 0; }
                                @foreach (var item in byPlatform)
                                {
                                    var color = palette[idx % palette.Length];
                                    <div class="legend-item @(selectedPlatform == item.Platform ? "active" : "")"
                                         @onclick="() => TogglePlatformFilter(item.Platform)" role="button">
                                        <span class="legend-dot" style="background:@color"></span>
                                        <span>@GetPlatformIcon(item.Platform) @item.Platform</span>
                                        <span class="legend-count">@item.Count</span>
                                    </div>
                                    idx++;
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== OS filter chips ===== -->
            <div class="os-filter mb-3">
                <span class="os-filter-label">Filter by OS:</span>
                <button class="os-chip @(selectedPlatform == null ? "active" : "")" @onclick="() => SetPlatformFilter(null)">All OS</button>
                @foreach (var os in availablePlatforms)
                {
                    <button class="os-chip @(selectedPlatform == os ? "active" : "")" @onclick="() => SetPlatformFilter(os)">
                        @GetPlatformIcon(os) @os
                    </button>
                }
            </div>

            @if (filteredAssignments.Any())
            {
                @if (viewMode == ViewMode.Cards)
                {
                    <div class="assignments-grid">
                        @foreach (var assignment in filteredAssignments)
                    {
                        <div class="assignment-card">
                            <div class="assignment-card-header">
                                <span class="policy-icon">@GetPolicyIcon(assignment.PolicyType)</span>
                                <span class="badge @GetBadgeClass(assignment.PolicyType)">@GetPolicyLabel(assignment.PolicyType)</span>
                            </div>
                            <h6 class="assignment-name">@assignment.PolicyName</h6>
                            <div class="assignment-meta">
                                @if (!string.IsNullOrEmpty(assignment.PolicySubType))
                                {
                                    <span class="meta-pill">@assignment.PolicySubType</span>
                                }
                                @if (!string.IsNullOrEmpty(assignment.Platform))
                                {
                                    <span class="meta-pill platform">@GetPlatformIcon(assignment.Platform) @assignment.Platform</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(assignment.Description))
                            {
                                <p class="assignment-desc">@TruncateDescription(assignment.Description)</p>
                            }
                            <div class="assignment-footer">
                                <span class="badge @GetIntentBadgeClass(assignment.AssignmentIntent)">
                                    @GetIntentIcon(assignment.AssignmentIntent) @GetIntentLabel(assignment.AssignmentIntent)
                                </span>
                                @if (!string.IsNullOrEmpty(assignment.AssignmentsUrl))
                                {
                                    <button class="details-btn" @onclick="() => OpenDetails(assignment)" title="View all assignment targets">
                                        🔍 Details
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover assignments-table">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Sub-type</th>
                                <th>Platform</th>
                                <th>Intent</th>
                                <th>Description</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in filteredAssignments)
                            {
                                <tr>
                                    <td><span class="row-icon">@GetPolicyIcon(a.PolicyType)</span></td>
                                    <td class="fw-semibold">@a.PolicyName</td>
                                    <td><span class="badge @GetBadgeClass(a.PolicyType)">@GetPolicyLabel(a.PolicyType)</span></td>
                                    <td>@a.PolicySubType</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(a.Platform))
                                        {
                                            <span>@GetPlatformIcon(a.Platform) @a.Platform</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetIntentBadgeClass(a.AssignmentIntent)">
                                            @GetIntentIcon(a.AssignmentIntent) @GetIntentLabel(a.AssignmentIntent)
                                        </span>
                                    </td>
                                    <td><small class="text-muted">@TruncateDescription(a.Description, 80)</small></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(a.AssignmentsUrl))
                                        {
                                            <button class="details-btn-sm" @onclick="() => OpenDetails(a)" title="View all assignment targets">
                                                🔍
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
                <p class="text-muted mt-3">Showing @filteredAssignments.Count of @assignments.Count assignment(s)</p>
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-icon">🔍</span>
                    <p>No assignments match the current filters.</p>
                    <button class="btn btn-outline-primary btn-sm" @onclick="ClearAllFilters">Clear filters</button>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <span class="empty-icon">📭</span>
                <p>No assignments found for this group.</p>
            </div>
        }
    }
</div>

@if (detailsAssignment != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseDetails"></div>
    <div class="modal-custom" role="dialog" aria-modal="true">
        <div class="modal-header-custom">
            <div>
                <div class="modal-pretitle">@GetPolicyIcon(detailsAssignment.PolicyType) @GetPolicyLabel(detailsAssignment.PolicyType) • @detailsAssignment.PolicySubType</div>
                <h4 class="modal-title-custom">@detailsAssignment.PolicyName</h4>
            </div>
            <button class="modal-close" @onclick="CloseDetails" aria-label="Close">✕</button>
        </div>
        <div class="modal-body-custom">
            @if (isLoadingDetails)
            {
                <div class="loading-state">
                    <div class="spinner-border spinner-border-sm text-primary"></div>
                    <span>Loading assignment targets...</span>
                </div>
            }
            else if (detailsList.Count == 0)
            {
                <div class="empty-state">
                    <span class="empty-icon">📭</span>
                    <p>No assignment targets returned for this policy.</p>
                </div>
            }
            else
            {
                <p class="text-muted small mb-3">@detailsList.Count target(s) — including assignments to other groups, All Users and All Devices.</p>
                <table class="table table-sm details-table">
                    <thead>
                        <tr>
                            <th>Target</th>
                            <th>Mode</th>
                            <th>Intent</th>
                            <th>Filter</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in detailsList)
                        {
                            <tr>
                                <td>
                                    <span class="target-icon">@GetTargetIcon(d.TargetType)</span>
                                    <span class="fw-semibold">@d.GroupName</span>
                                    @if (d.TargetType == AssignmentTargetType.AllUsers || d.TargetType == AssignmentTargetType.AllDevices)
                                    {
                                        <span class="badge bg-info text-dark ms-1">Virtual</span>
                                    }
                                    @if (!string.IsNullOrEmpty(d.GroupId))
                                    {
                                        <div><small class="text-muted">@d.GroupId</small></div>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(d.IsExcluded ? "bg-danger" : "bg-success")">
                                        @(d.IsExcluded ? "⛔ Exclude" : "✓ Include")
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.Intent))
                                    {
                                        <span class="badge @GetIntentBadgeClass(d.Intent)">
                                            @GetIntentIcon(d.Intent) @d.Intent
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(d.FilterType))
                                    {
                                        <span class="badge bg-light text-dark">@d.FilterType</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private enum ViewMode { Cards, Table }

    private string searchTerm = string.Empty;
    private List<GroupInfo> groups = new();
    private GroupInfo? selectedGroup;
    private List<IntuneAssignment> assignments = new();
    private List<IntuneAssignment> filteredAssignments = new();
    private PolicyType? selectedFilter;
    private string? selectedPlatform;
    private List<string> availablePlatforms = new();
    private ViewMode viewMode = ViewMode.Cards;
    private bool isSearching;
    private bool isLoadingAssignments;
    private System.Timers.Timer? debounceTimer;

    // Details modal state
    private IntuneAssignment? detailsAssignment;
    private List<PolicyAssignmentDetail> detailsList = new();
    private bool isLoadingDetails;

    private static readonly (PolicyType type, string icon, string label)[] PolicyTypeMeta = new[]
    {
        (PolicyType.Configuration, "⚙️", "Configuration"),
        (PolicyType.AdministrativeTemplate, "🧾", "Admin Templates"),
        (PolicyType.Compliance, "✅", "Compliance"),
        (PolicyType.Application, "📦", "Applications"),
        (PolicyType.AppProtection, "🛡️", "App Protection"),
        (PolicyType.AppConfiguration, "🧩", "App Config"),
        (PolicyType.EndpointSecurity, "🔒", "Endpoint Security"),
        (PolicyType.Script, "📜", "Scripts"),
        (PolicyType.Provisioning, "🚀", "Provisioning"),
    };

    private async Task OnSearchInput()
    {
        debounceTimer?.Stop();
        debounceTimer?.Dispose();

        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 3)
        {
            groups.Clear();
            return;
        }

        debounceTimer = new System.Timers.Timer(400) { AutoReset = false };
        debounceTimer.Elapsed += async (s, e) =>
        {
            await InvokeAsync(async () =>
            {
                await SearchGroups();
                StateHasChanged();
            });
        };
        debounceTimer.Start();
    }

    private async Task SearchGroups()
    {
        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 3) return;
        isSearching = true;
        StateHasChanged();
        try
        {
            groups = await IntuneService.SearchGroupsAsync(searchTerm.Trim());
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task SelectGroup(GroupInfo group)
    {
        selectedGroup = group;
        groups.Clear();
        searchTerm = string.Empty;
        selectedFilter = null;
        await LoadAssignments();
    }

    private async Task SelectAllUsers()
    {
        await SelectGroup(new GroupInfo
        {
            Id = IntuneAssignmentViewer.Services.IntuneService.VirtualAllUsersId,
            DisplayName = "All Users (virtual)",
            Description = "Every licensed user in the tenant"
        });
    }

    private async Task SelectAllDevices()
    {
        await SelectGroup(new GroupInfo
        {
            Id = IntuneAssignmentViewer.Services.IntuneService.VirtualAllDevicesId,
            DisplayName = "All Devices (virtual)",
            Description = "Every Intune-enrolled device"
        });
    }

    private bool IsVirtualGroup => selectedGroup != null
        && (selectedGroup.Id == IntuneAssignmentViewer.Services.IntuneService.VirtualAllUsersId
         || selectedGroup.Id == IntuneAssignmentViewer.Services.IntuneService.VirtualAllDevicesId);

    private void ClearSelection()
    {
        selectedGroup = null;
        assignments.Clear();
        filteredAssignments.Clear();
        availablePlatforms.Clear();
        selectedFilter = null;
        selectedPlatform = null;
        searchTerm = string.Empty;
    }

    private void ClearAllFilters()
    {
        selectedFilter = null;
        selectedPlatform = null;
        ApplyFilters();
    }

    private void SetFilter(PolicyType? filter)
    {
        selectedFilter = filter;
        ApplyFilters();
    }

    private void SetPlatformFilter(string? platform)
    {
        selectedPlatform = platform;
        ApplyFilters();
    }

    private void TogglePlatformFilter(string platform)
    {
        selectedPlatform = (selectedPlatform == platform) ? null : platform;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        IEnumerable<IntuneAssignment> q = assignments;
        if (selectedFilter != null)
            q = q.Where(a => a.PolicyType == selectedFilter);
        if (!string.IsNullOrEmpty(selectedPlatform))
        {
            q = (selectedPlatform == "Cross-platform")
                ? q.Where(a => string.IsNullOrEmpty(a.Platform))
                : q.Where(a => a.Platform == selectedPlatform);
        }
        filteredAssignments = q.ToList();
    }

    private async Task LoadAssignments()
    {
        if (selectedGroup == null) return;
        isLoadingAssignments = true;
        StateHasChanged();
        try
        {
            assignments = await IntuneService.GetAssignmentsForGroupAsync(selectedGroup.Id, null);
            availablePlatforms = assignments
                .Select(a => string.IsNullOrEmpty(a.Platform) ? "Cross-platform" : a.Platform)
                .Distinct()
                .OrderBy(p => p)
                .ToList();
            ApplyFilters();
        }
        finally
        {
            isLoadingAssignments = false;
        }
    }

    private async Task RefreshAssignments()
    {
        IntuneService.InvalidateCache();
        await LoadAssignments();
    }

    private static string GetPolicyIcon(PolicyType type) => type switch
    {
        PolicyType.Configuration => "⚙️",
        PolicyType.AdministrativeTemplate => "🧾",
        PolicyType.Compliance => "✅",
        PolicyType.Application => "📦",
        PolicyType.AppProtection => "🛡️",
        PolicyType.AppConfiguration => "🧩",
        PolicyType.EndpointSecurity => "🔒",
        PolicyType.Script => "📜",
        PolicyType.Provisioning => "🚀",
        _ => "📄"
    };

    private static string GetPolicyLabel(PolicyType type) => type switch
    {
        PolicyType.AdministrativeTemplate => "Admin Template",
        PolicyType.AppProtection => "App Protection",
        PolicyType.AppConfiguration => "App Config",
        PolicyType.EndpointSecurity => "Endpoint Security",
        _ => type.ToString()
    };

    private static string GetBadgeClass(PolicyType type) => type switch
    {
        PolicyType.Configuration => "bg-info text-dark",
        PolicyType.AdministrativeTemplate => "bg-secondary",
        PolicyType.Compliance => "bg-warning text-dark",
        PolicyType.Application => "bg-primary",
        PolicyType.AppProtection => "bg-danger",
        PolicyType.AppConfiguration => "bg-success",
        PolicyType.EndpointSecurity => "bg-dark",
        PolicyType.Script => "bg-info",
        PolicyType.Provisioning => "bg-purple",
        _ => "bg-secondary"
    };

    private static string GetBarColorClass(PolicyType type) => type switch
    {
        PolicyType.Configuration => "bar-blue",
        PolicyType.AdministrativeTemplate => "bar-gray",
        PolicyType.Compliance => "bar-orange",
        PolicyType.Application => "bar-indigo",
        PolicyType.AppProtection => "bar-red",
        PolicyType.AppConfiguration => "bar-green",
        PolicyType.EndpointSecurity => "bar-dark",
        PolicyType.Script => "bar-teal",
        PolicyType.Provisioning => "bar-purple",
        _ => "bar-gray"
    };

    private async Task OpenDetails(IntuneAssignment a)
    {
        detailsAssignment = a;
        detailsList = new();
        isLoadingDetails = true;
        StateHasChanged();
        try
        {
            detailsList = await IntuneService.GetPolicyAssignmentsAsync(a.AssignmentsUrl);
        }
        finally
        {
            isLoadingDetails = false;
            StateHasChanged();
        }
    }

    private void CloseDetails()
    {
        detailsAssignment = null;
        detailsList.Clear();
    }

    private static string GetTargetIcon(AssignmentTargetType t) => t switch
    {
        AssignmentTargetType.AllUsers => "🧑‍🤝‍🧑",
        AssignmentTargetType.AllDevices => "💻",
        AssignmentTargetType.Group => "👥",
        _ => "❓"
    };

    private static string GetPlatformIcon(string platform) => platform.ToLowerInvariant() switch
    {
        var s when s.Contains("windows 365") => "☁️",
        var s when s.Contains("windows") => "🪟",
        "ios" => "🍎",
        "macos" => "🖥️",
        "android" => "🤖",
        "cross-platform" => "🌐",
        _ => "📱"
    };

    private static string GetIntentIcon(string intent) => intent.ToLowerInvariant() switch
    {
        "exclude" or "excluded" => "⛔",
        "uninstall" => "🗑️",
        "available" => "📥",
        "required" => "📌",
        _ => "✓"
    };

    private static string GetIntentLabel(string intent) => intent.ToLowerInvariant() switch
    {
        // For policies (configurations, compliance, scripts, etc.) "include" means the group
        // is targeted to receive the policy. Use "Assigned" for clarity.
        "include" => "Assigned",
        "exclude" => "Excluded",
        _ => intent
    };

    private static string GetIntentBadgeClass(string intent) => intent.ToLowerInvariant() switch
    {
        "exclude" or "excluded" => "bg-danger",
        "uninstall" => "bg-warning text-dark",
        "available" => "bg-info text-dark",
        "required" => "bg-primary",
        _ => "bg-success"
    };

    private static string TruncateDescription(string description, int max = 120)
    {
        if (string.IsNullOrEmpty(description)) return "";
        return description.Length > max ? description[..max] + "..." : description;
    }

    public void Dispose()
    {
        debounceTimer?.Dispose();
    }
}