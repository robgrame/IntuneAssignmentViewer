@page "/"
@inject IOptions<BrandingSettings> BrandingOptions
@inject IConfiguration Configuration

<PageTitle>@BrandingOptions.Value.AppTitle</PageTitle>

<AuthorizeView>
    <Authorized>
        @{
            var requiredRole = Configuration.GetValue<string>("Authorization:RequiredRole") ?? "IntuneReader";
            var hasRole = context.User.IsInRole(requiredRole);
        }
        @if (hasRole)
        {
            <div class="home-hero">
                <div class="hero-icon">🛡️</div>
                <h1>Welcome to @BrandingOptions.Value.AppTitle</h1>
                <p class="lead">Search any Entra ID group and instantly view all Intune assignments targeting it.</p>
                <a href="assignments" class="btn btn-primary btn-lg mt-3">Go to Assignments →</a>
            </div>

            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon">⚙️</div>
                    <h5>Configuration</h5>
                    <p>Device configuration, Settings Catalog and Administrative Templates.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">✅</div>
                    <h5>Compliance</h5>
                    <p>Compliance policies across all supported platforms.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📦</div>
                    <h5>Applications</h5>
                    <p>All app types: Win32, LOB, Store, web apps and more.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔒</div>
                    <h5>Security &amp; Protection</h5>
                    <p>Endpoint security intents and app protection policies.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📜</div>
                    <h5>Scripts</h5>
                    <p>PowerShell scripts (Windows) and Shell scripts (macOS).</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🧩</div>
                    <h5>App Configuration</h5>
                    <p>Managed device and managed app configuration policies.</p>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger mt-4">
                <h4 class="alert-heading">⛔ Access Denied</h4>
                <p>You are authenticated as <strong>@context.User.Identity?.Name</strong>, but you do not have the required role (<code>@requiredRole</code>) to access this application.</p>
                <hr />
                <p class="mb-0">Please contact your administrator to be assigned the correct role.</p>
            </div>
            <a href="MicrosoftIdentity/Account/SignOut" class="btn btn-outline-secondary mt-3">Sign Out</a>
        }
    </Authorized>
    <NotAuthorized>
        <div class="splash-container">
            <div class="splash-card">
                <div class="splash-logo">
                    <img src="@BrandingOptions.Value.LogoPath" alt="Logo" onerror="this.style.display='none'" />
                </div>
                <h1 class="splash-title">@BrandingOptions.Value.AppTitle</h1>
                <p class="splash-tagline">View Microsoft Intune assignments for any Entra ID group, in one place.</p>

                <div class="splash-features">
                    <div class="splash-feature"><span>⚙️</span> Configuration policies</div>
                    <div class="splash-feature"><span>✅</span> Compliance policies</div>
                    <div class="splash-feature"><span>📦</span> Applications</div>
                    <div class="splash-feature"><span>🔒</span> Endpoint Security</div>
                    <div class="splash-feature"><span>📜</span> Scripts</div>
                    <div class="splash-feature"><span>🧩</span> App Configurations</div>
                </div>

                <a href="MicrosoftIdentity/Account/SignIn" class="btn btn-primary btn-lg splash-signin-btn">
                    <span class="ms-logo">⊞</span> Sign in with Microsoft
                </a>

                <p class="splash-footer-note">Secure authentication powered by Microsoft Entra ID</p>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
