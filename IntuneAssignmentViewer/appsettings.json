{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "Graph": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "CertificateThumbprint": "",
    "CertificateStoreLocation": "LocalMachine",
    "CertificateStoreName": "My",
    "CertificatePath": "",
    "CertificatePassword": "",
    "CertificateBase64": ""
  },
  "CookiePolicy": {
    "Secure": "Always"
  },
  "Authorization": {
    "RequiredRole": "IntuneReader"
  },
  "Cache": {
    "CatalogTtlMinutes": 10,
    "AssignmentsTtlMinutes": 10,
    "GroupNamesTtlMinutes": 30,
    "NegativeTtlMinutes": 1,
    "MaxSizeMegabytes": 64
  },
  "Performance": {
    "EnableBatchRequests": true,
    "BatchSize": 20,
    "MaxConcurrentGraphRequests": 10,
    "BatchSpacingMs": 100
  },
  "Warmup": {
    "Enabled": false,
    "InitialDelaySeconds": 60,
    "IntervalMinutes": 10
  },
  "Branding": {
    "LogoPath": "/images/logo.svg",
    "AppTitle": "Intune Assignment Viewer"
  }
}
