{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "Graph": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": ""
  },
  "CookiePolicy": {
    "Secure": "Always"
  },
  "Authorization": {
    "RequiredRole": "IntuneReader"
  },
  "Cache": {
    "CatalogTtlMinutes": 10,
    "AssignmentsTtlMinutes": 10,
    "GroupNamesTtlMinutes": 30,
    "NegativeTtlMinutes": 1
  },
  "Performance": {
    "EnableBatchRequests": true,
    "BatchSize": 20,
    "MaxConcurrentGraphRequests": 10,
    "BatchSpacingMs": 100
  },
  "Warmup": {
    "Enabled": false,
    "InitialDelaySeconds": 60,
    "IntervalMinutes": 10
  },
  "Branding": {
    "LogoPath": "/images/logo.svg",
    "AppTitle": "Intune Assignment Viewer"
  }
}
